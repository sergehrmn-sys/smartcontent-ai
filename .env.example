# SmartContent AI — exemple de configuration
# Copie ce fichier en `.env` et remplis tes vraies clés.
# ⚠️ NE JAMAIS commiter le fichier .env (il est dans .gitignore).

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_MODEL=gpt-4o

# Supabase — https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_SECRET=sb_secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Auth
SECRET_KEY=change-this-to-a-random-32-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# n8n — Production mode (workflow doit etre Published dans n8n)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/smartcontent-publish

# App
APP_ENV=development
APP_PORT=8001
